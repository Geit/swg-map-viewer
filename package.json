{
  "name": "swg-map-viewer",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "9.39.5",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "sharp": "^0.35.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0"
  },
  "scripts": {
    "start": "yarn workspace @swg-map-viewer/frontend run start",
    "lint": "eslint . && npm run typecheck",
    "build": "yarn workspace @swg-map-viewer/frontend run build",
    "preview": "yarn workspace @swg-map-viewer/frontend run preview",
    "generate-tiles": "yarn ts-node-script scripts/generate-tiles.ts",
    "generate-capture-tiles": "yarn ts-node-script scripts/generate-capture-tiles.ts",
    "typecheck": "yarn workspace @swg-map-viewer/frontend run typecheck"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "dependencies": {}
}
