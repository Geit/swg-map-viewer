{
  "compilerOptions": {
    "target": "es2022",
    // moduleResolution "node" is deprecated in TS 6.0 but kept intentionally:
    // these scripts run under ts-node in CommonJS mode, and node resolution is
    // required for its extensionless relative/bare imports. Revisit for TS 7.
    "ignoreDeprecations": "6.0",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": true,
    "jsx": "react"
  },
  "include": [
    "../src", "."
  ]
}
